# Firebase credentials — the only local config file needed.
# Everything else (Telegram token, instance list, etc.) is stored in Firestore.
#
# Copy to credentials.yaml and fill in your values:
#   cp credentials.yaml.example credentials.yaml
#
# DO NOT commit credentials.yaml to git.

firebase:
  api_key: "your-firebase-api-key"
  database_url: "https://your-project-default-rtdb.firebaseio.com"
  auth_domain: "your-project.firebaseapp.com" # optional at runtime, used by `login`
  project_id: "your-project"                  # optional at runtime, used by `login`
  refresh_token: ""                           # set by `./bin/opencode-manager login`

# Unique identifier for this Go client process.
# Auto-generated on first run if empty.
client_id: ""
