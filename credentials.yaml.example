# Firebase credentials — the only local config file needed.
# Everything else (Telegram token, instance list, etc.) is stored in Firebase.
#
# Copy to credentials.yaml and fill in your values:
#   cp credentials.yaml.example credentials.yaml
#
# DO NOT commit credentials.yaml to git.

firebase:
  api_key: "your-firebase-api-key"
  database_url: "https://your-project-default-rtdb.firebaseio.com"
  email: "go-bot@your-project.local"
  password: "your-password"

# Optional: override the local database path (for instance state cache).
# Default: ./data/opencode-manager.db
# db_path: "./data/opencode-manager.db"
