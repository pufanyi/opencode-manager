rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Instances: any authenticated user can CRUD.
    match /instances/{instanceId} {
      allow read, write: if request.auth != null;
    }

    // Sessions: any authenticated user can CRUD.
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;

      // Message history subcollection.
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // User state: users can only access their own state.
    match /user_state/{userId} {
      allow read, write: if request.auth != null;
    }

    // Message sessions (Telegram message → session mapping).
    match /message_sessions/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settings: any authenticated user can read/write.
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
